          "content": "use std::abi::sol\nuse std::evm::{Evm, Call}\nuse std::evm::effects::assert\n\nmsg CounterMsg {\n    #[selector = sol(\"increment()\")]\n    Increment,\n    #[selector = sol(\"get()\")]\n    Get -> u256,\n}\n\nstruct CounterStore {\n    value: u256,\n}\n\npub contract Counter {\n    mut store: CounterStore\n\n    init() uses (mut store) {\n        store.value = 0\n    }\n\n    recv CounterMsg {\n        Increment uses (mut store) {\n            store.value = store.value + 1\n        }\n\n        Get -> u256 uses (store) {\n            store.value\n        }\n    }\n}\n"
